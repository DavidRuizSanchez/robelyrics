# =============================================================
# RobeLyrics — variables de entorno
# Copia este fichero a .env y rellena los valores reales.
# NUNCA commitees .env (está en .gitignore).
# =============================================================

# ----- Postgres -----
POSTGRES_USER=robelyrics
POSTGRES_PASSWORD=changeme_robelyrics
POSTGRES_DB=robelyrics
POSTGRES_PORT=5435

# URL completa que usa la api (host=postgres dentro de la red docker)
DATABASE_URL=postgresql+psycopg://robelyrics:changeme_robelyrics@postgres:5432/robelyrics

# ----- Qdrant -----
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://qdrant:6333

# ----- API (FastAPI) -----
API_PORT=8001
API_LOG_LEVEL=info

# JWT — generar con: openssl rand -hex 32
JWT_SECRET=replace_me_with_openssl_rand_hex_32
JWT_ALGO=HS256
JWT_TTL_MIN=43200          # 30 días
BCRYPT_ROUNDS=12

# Usuario admin inicial (se sembrará en la migración de auth)
ADMIN_EMAIL=tu@email.com
ADMIN_PASSWORD=changeme_admin_password

# ----- Web (Next.js) -----
WEB_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:8001

# ----- Servicios externos -----
# Genius API token: https://genius.com/api-clients (crear app, copiar Client Access Token)
GENIUS_TOKEN=

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ----- Reddit (PRAW) — solo si se ejecuta scripts/research/fetch_reddit.py -----
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=robelyrics-research/1.0 (by u/your_reddit_user)

# ----- YouTube Data API v3 — solo para fetch de comentarios destacados -----
YOUTUBE_API_KEY=
